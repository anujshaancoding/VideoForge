{
  "name": "@videoforge/render-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VideoForge render worker — BullMQ + FFmpeg stub proving the §10.2 render path shape (MVP-STUB: builds + logs the ffmpeg argv, does not spawn).",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"no lint config in @videoforge/render-worker\" && exit 0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@sentry/node": "^8.54.0",
    "@videoforge/ffmpeg-graph": "workspace:*",
    "@videoforge/project-schema": "workspace:*",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@videoforge/config": "workspace:*",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
