{
  "extends": "@videoforge/config/tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "references": [
    { "path": "../../packages/project-schema" },
    { "path": "../../packages/ffmpeg-graph" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
