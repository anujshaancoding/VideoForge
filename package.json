{
  "name": "videoforge",
  "version": "0.0.0",
  "private": true,
  "description": "VideoForge — browser-based, what-you-cut-is-what-you-get video editor (Free-tier MVP).",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:all": "node scripts/dev.mjs",
    "dev:api": "corepack pnpm@9.12.0 --filter @videoforge/api dev",
    "dev:web": "corepack pnpm@9.12.0 --filter @videoforge/web dev",
    "dev:worker": "docker compose up render-worker",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "check:ffmpeg": "node scripts/check-ffmpeg.mjs",
    "services:up": "docker compose up -d --wait",
    "services:down": "docker compose down",
    "services:reset": "docker compose down -v",
    "test:golden": "pnpm --filter @videoforge/ffmpeg-graph test:golden",
    "test:perf": "tsx scripts/perf-gate.ts",
    "generate:fixtures": "tsx scripts/generate-fixtures.ts",
    "seed": "pnpm seed:storage && pnpm seed:db",
    "seed:storage": "tsx infra/minio/seed.ts",
    "seed:db": "tsx infra/db/seed.ts",
    "db:migrate": "pnpm --filter @videoforge/api db:migrate",
    "test:e2e": "./node_modules/.bin/playwright test",
    "test:e2e:ui": "./node_modules/.bin/playwright test --ui",
    "test:e2e:headed": "./node_modules/.bin/playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
