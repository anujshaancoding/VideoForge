# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.turbo/

# Environment
.env
.env.local
.env.*.local
# Now holds the real super-account credential, so it must NOT be committed.
.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Test outputs
test-results/
playwright-report/
e2e-report/
coverage/
# Playwright auth storageState (contains session cookies — never commit)
e2e/.auth/

# Local access credentials — plaintext logins for the running dev stack. NEVER commit.
company/ACCESS.md

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# Fixtures: NO Git LFS (Anchor CI decision). Golden frames under fixtures/golden/
# are committed as regular, diff-reviewable PNG git blobs. Synthetic media under
# fixtures/media/ is regenerated by `pnpm generate:fixtures` and is NOT committed.
fixtures/media/*.mp4
fixtures/media/*.wav
fixtures/media/.golden-work/

# Docker
.dockerignore

# Misc
*.pid
*.seed
*.pid.lock

# Downloaded Valorant asset pack (Riot IP — re-fetch via scripts/asset-packs/valorant-pack.mjs; images not committed)
assets/valorant/**/*.png
assets/valorant/previews/*.png
assets/valorant/storyboards/**/*.png

# Stray local-only files (never commit)
gglobby content assest/
apps/api/_dbg.mjs
