# ───────────────────────── VideoForge .env.example ─────────────────────────
# Copy to .env for first run:  cp .env.example .env
# Loaded by apps/api, apps/render-worker, and the seed scripts.
# apps/web reads ONLY VITE_-prefixed vars (Vite exposes nothing else to the browser).
# Never commit .env. Values below are dev defaults consistent with Pipeline.md §2.

# ── Node / runtime ──
NODE_ENV=development

# ── Postgres (project JSONB, assets, users, exports) ──
DATABASE_URL=postgresql://videoforge:videoforge_dev@localhost:5432/videoforge

# ── Redis (BullMQ render + proxy/thumbnail/waveform queues) ──
REDIS_URL=redis://localhost:6379

# ── S3 double: MinIO (local-disk S3 — the only storage backend in dev/CI, MVP_Scope §6) ──
# In prod these point at real S3; in dev they point at the docker-compose MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true            # required for MinIO path-style addressing
S3_BUCKET=videoforge                # single MVP bucket; prefixes originals/ proxies/ exports/

# ── API server ──
API_HOST=0.0.0.0
API_PORT=4000
WEB_ORIGIN=http://localhost:5173    # CORS allow-list + WS origin check

# ── Auth (JWT access 15m + rotating refresh httpOnly cookie) ──
JWT_SECRET=dev_jwt_secret_change_me
JWT_ACCESS_TTL=900                  # 15 minutes (seconds)
JWT_REFRESH_TTL=2592000             # 30 days (seconds)
GOOGLE_OAUTH_CLIENT_ID=             # blank disables the Google sign-in button
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# ── Billing: STUBBED for MVP (Free-tier only). Do NOT wire Stripe. ──
BILLING_MODE=stub                   # 'stub' is the only supported value in Phase 0

# ── Render worker / FFmpeg (pinned build — Pipeline.md §2.6) ──
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe
FFMPEG_PINNED_VERSION=6.1.1         # asserted by the worker on boot & in CI
RENDER_CONCURRENCY=1                # single worker pool in MVP (no autoscale)
EXPORT_RATE_LIMIT_PER_MIN=5         # per-user export rate limit (spec §17.4)

# ── Observability (minimal in MVP: Sentry + funnel events; spec §20) ──
SENTRY_DSN=                         # blank in local dev (no-op)

# ── Frontend (only VITE_-prefixed vars reach the browser bundle) ──
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_WS_URL=ws://localhost:4000/ws
VITE_PLAN=free                      # hard-coded Free tier; gates UI controls
