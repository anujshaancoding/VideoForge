# ───────────────────────── VideoForge .env.example ─────────────────────────
# Copy to .env for first run:  cp .env.example .env   (or: make env)
# Loaded by apps/api, apps/render-worker, and the seed scripts.
# apps/web reads ONLY VITE_-prefixed vars (Vite exposes nothing else to the browser).
# Never commit .env. Values below are dev defaults consistent with Pipeline.md §2.
#
# These keys are the AUTHORITATIVE contract the code reads — copying this file
# verbatim to .env yields a working dev runtime against docker-compose.

# ── Node / runtime ──
NODE_ENV=development

# ── Postgres (project JSONB, assets, users, exports) ──
# The render-worker reads DATABASE_URL; docker-compose composes the same value
# from POSTGRES_* below and overrides the host to the `postgres` service DNS.
DATABASE_URL=postgresql://videoforge:videoforge_dev@localhost:5432/videoforge
POSTGRES_DB=videoforge
POSTGRES_USER=videoforge
POSTGRES_PASSWORD=videoforge_dev

# ── Redis (BullMQ render + proxy/thumbnail/waveform queues, export rate-limit) ──
# REDIS_URL takes precedence; REDIS_HOST/REDIS_PORT are the fallback the code uses
# when REDIS_URL is unset.
REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── S3 / MinIO (local-disk S3 double — the only storage backend in dev/CI, MVP_Scope §6) ──
# In prod these point at real S3; in dev they point at the docker-compose MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true            # required for MinIO path-style addressing
# Three buckets (the code reads each separately; there is NO single-bucket mode):
S3_BUCKET_ORIGINALS=vf-originals    # immutable uploaded source media
S3_BUCKET_PROXIES=vf-proxies        # transcoded edit/preview proxies + thumbnails/waveforms
S3_BUCKET_EXPORTS=vf-exports        # rendered MP4 outputs (7-day download lifecycle)

# ── API server ──
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
WEB_ORIGIN=http://localhost:5173    # CORS allow-list + WS origin check

# ── Auth (JWT access + rotating refresh) ──
JWT_ACCESS_SECRET=dev_jwt_access_secret_change_me
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_me

# ── Render worker / FFmpeg (pinned build — Pipeline.md §2.6) ──
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe
FFMPEG_PINNED_VERSION=6.1.1         # asserted by the worker on boot, by `make check-ffmpeg`, and in CI
RENDER_CONCURRENCY=1                # single render pool in MVP (no autoscale)
MEDIA_CONCURRENCY=2                 # proxy/thumbnail/waveform job concurrency
EXPORT_RATE_LIMIT_PER_MIN=5         # per-user export rate limit (spec §17.4)
# WATERMARK_PATH=                   # optional Free-tier watermark overlay PNG

# ── Script Studio v2 (planner + TTS + music; Contract C) ──
GROQ_API_KEY=                       # Groq free-tier key (no purchase) → set in .env, NOT here. BLANK → planner falls back to the key-free heuristic
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b       # strict json_schema (constrained decoding) model
# GROQ_TIMEOUT_MS=20000             # per-call timeout; on timeout → heuristic fallback
TTS_ENGINE=kokoro                   # kokoro (kokoro-js, CPU, q8) | piper (binary, behind the same seam)
KOKORO_MODEL=onnx-community/Kokoro-82M-v1.0-ONNX
KOKORO_VOICE=af_heart               # default Kokoro voice (28+ EN voices; overridable per request voiceId)
# SCRIPT_WORKER_DISABLED=false      # set true to NOT spin the in-process `script` worker (e.g. tests)

# ── Script Studio v2 — sketch visuals (auto-illustrate scenes at $0) ──
# Defaults are tuned for SDXL Turbo (researched 2026-06-17): ADD-distilled → few steps,
# NO guidance, Euler-a, near-native 512×896 (generating far above native duplicates the
# subject). The sketch filter upscales each frame to the 1080×1920 canvas afterwards.
IMAGEGEN_ENGINE=auto                 # auto (drawthings → pollinations → placeholder) | drawthings | pollinations
DRAWTHINGS_URL=http://127.0.0.1:7860 # Draw Things' local A1111-compatible HTTP API (Settings → Advanced → API Server)
# IMAGEGEN_STEPS=3                   # Turbo wants 1–4; >5 over-cooks ("oily"/fried)
# IMAGEGEN_CFG=1                     # Turbo = no guidance; CFG>2 = the fried/HDR look
# IMAGEGEN_SAMPLER=Euler a           # Turbo's trained sampler (NOT DPM++ 2M/AYS); blank ⇒ Draw Things default
# IMAGEGEN_WIDTH=512                 # near Turbo's native; generating bigger duplicates subjects
# IMAGEGEN_HEIGHT=896                # 9:16 portrait at native-ish scale; filter upscales to 1080×1920
# IMAGEGEN_TIMEOUT_MS=180000         # per-image timeout (covers cold model load)
# POLLINATIONS_SPACING_MS=16000      # spacing between keyless-cloud calls (anon rate limit ~1/15s)

# ── Observability (minimal in MVP: Sentry + funnel events; spec §20) ──
SENTRY_DSN=                         # blank in local dev (no-op)
VITE_SENTRY_DSN=                    # browser-exposed Sentry DSN (Vite exposes VITE_* only); blank in local dev

# ── Frontend (only VITE_-prefixed vars reach the browser bundle) ──
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_WS_URL=ws://localhost:4000/ws
