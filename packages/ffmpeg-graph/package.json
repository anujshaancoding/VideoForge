{
  "name": "@videoforge/ffmpeg-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VideoForge headless 'what-you-cut-is-what-you-get' FFmpeg filter_complex command builder (§10.3). Pure, deterministic, unit-testable — no fs, no spawn.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run --reporter=verbose src/__tests__/golden.test.ts"
  },
  "dependencies": {
    "@videoforge/project-schema": "workspace:*"
  },
  "devDependencies": {
    "@videoforge/config": "workspace:*",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
