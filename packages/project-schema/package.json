{
  "name": "@videoforge/project-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VideoForge project document data model (§18) — TypeScript types, Zod runtime validator, and a valid sample fixture.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@videoforge/config": "workspace:*",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
